# Active login uses Supabase Auth with Google provider.
# Pass SUPABASE_URL and SUPABASE_ANON_KEY to the Flutter apps with --dart-define.
# Firebase values below are optional legacy fields and are not required for the active Supabase login flow.

# Firebase Configuration (legacy/optional)
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# OR provide individual service account keys:
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# OTP Configuration
# Legacy fallback only. Active frontend login now uses Supabase Google sign-in.
OTP_PROVIDER=supabase
OTP_EXPIRATION_TIME=600

# Twilio Configuration (if using Twilio for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=
EMAIL_FROM=noreply@alifschool.com
EMAIL_FROM_NAME=Alif School

# Storage Configuration
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=alif-school

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database
DB_POOL_MIN=2
DB_POOL_MAX=10
